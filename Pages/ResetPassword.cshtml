@page
@model AuthX.Pages.ResetPasswordModel

<h2>Reset Password</h2>
<form method="post">
    <div>
        <label>Token</label>
        <input asp-for="Token" />
    </div>
    <div>
        <label>New Password</label>
        <input asp-for="NewPassword" type="password" />
    </div>
    <button type="submit">Reset password</button>
</form>

<p>@Model.Message</p>