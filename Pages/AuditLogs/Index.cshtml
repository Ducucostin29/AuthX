@page
@model AuthX.Pages.AuditLogs.IndexModel

@{
    ViewData["Title"] = "Audit Logs";
}

<h2 class="mb-4">Audit Logs</h2>

<div class="card p-3">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>Time</th>
                <th>User ID</th>
                <th>Action</th>
                <th>Resource</th>
                <th>Resource ID</th>
                <th>IP Address</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var log in Model.Logs)
        {
            <tr>
                <td>@log.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
                <td>@log.UserId</td>
                <td>
                    <span class="badge bg-dark">@log.Action</span>
                </td>
                <td>@log.Resource</td>
                <td>@log.ResourceId</td>
                <td>@log.IpAddress</td>
            </tr>
        }
        </tbody>
    </table>

    @if (!Model.Logs.Any())
    {
        <div class="text-center text-muted p-4">
            No audit logs found.
        </div>
    }
</div>