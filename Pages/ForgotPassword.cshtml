@page
@model AuthX.Pages.ForgotPasswordModel

<h2>Forgot Password</h2>
<form method="post">
    <label>Email</label>
    <input asp-for="Email" />
    <button type="submit">Generate reset token</button>
</form>

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <p>@Model.Message</p>
}

@if (!string.IsNullOrWhiteSpace(Model.GeneratedToken))
{
    <p>Demo token: @Model.GeneratedToken</p>
}