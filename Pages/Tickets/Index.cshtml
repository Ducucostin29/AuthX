@page
@model AuthX.Pages.Tickets.IndexModel

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">My Tickets</h2>

        <a asp-page="/Tickets/Create" class="btn btn-primary">
            Create Ticket
        </a>
    </div>

    <div class="card p-3">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Title</th>
                    <th>Severity</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th class="text-end">Action</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var ticket in Model.Tickets)
            {
                <tr>
                    <td>@ticket.Title</td>

                    <td>
                        @if (ticket.Severity == "HIGH")
                        {
                            <span class="badge bg-danger">HIGH</span>
                        }
                        else if (ticket.Severity == "MED")
                        {
                            <span class="badge bg-warning text-dark">MED</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">LOW</span>
                        }
                    </td>

                    <td>
                        @if (ticket.Status == "OPEN")
                        {
                            <span class="badge bg-primary">OPEN</span>
                        }
                        else if (ticket.Status == "IN_PROGRESS")
                        {
                            <span class="badge bg-info text-dark">IN PROGRESS</span>
                        }
                        else
                        {
                            <span class="badge bg-success">RESOLVED</span>
                        }
                    </td>

                    <td>@ticket.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>

                    <td class="text-end">
                        <a asp-page="/Tickets/Details"
                           asp-route-id="@ticket.Id"
                           class="btn btn-sm btn-outline-primary">
                            View
                        </a>
                    </td>
                </tr>
            }
            </tbody>
        </table>

        @if (!Model.Tickets.Any())
        {
            <div class="text-center p-4 text-muted">
                No tickets found.
            </div>
        }
    </div>
</div>